saldo = 1500.0
LIMITE_SAQUE = 3
saques_realizados = 0   

opcion = int(input("[1] Sacar\n[2] Extrato\n[3] Depósito\n[0] Sair\nDigite a opção desejada: "))

if opcion == 1:
    if saques_realizados >= LIMITE_SAQUE:
        print("Limite diário de saques atingido!")
    else:
        valor = float(input("Digite a quantia para o saque (máximo R$ 500): "))
        if valor > 500:
            print("O valor máximo para saque é R$ 500.")
        elif valor <= saldo:
            saldo -= valor
            saques_realizados += 1
            print("Saque realizado com sucesso!")
            print(f"Saldo atual: R$ {saldo:.2f}")
        else:
            print("Saldo insuficiente para saque!")

elif opcion == 2:  
    print(f"Saldo atual: R$ {saldo:.2f}")
    print(f"Saques realizados hoje: {saques_realizados}/{LIMITE_SAQUE}")

elif opcion == 3:
    deposito = float(input("Digite a quantia para o depósito: "))
    if deposito > 0:
        saldo += deposito
        print("Depósito realizado com sucesso!")
        print(f"Saldo atual: R$ {saldo:.2f}")
    else:
        print("nao foi possivel realizar o depósito!")

elif opcion == 0:
    print("Obrigado por usar nosso sistema bancário. Até logo!")

else:
    print("Opção inválida! Por favor, escolha uma opção válida.")